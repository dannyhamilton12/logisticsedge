---
/**
 * TableOfContents — Auto-generated from article headings.
 * Place inside the article layout before the prose content.
 * Uses client-side JS to parse h2/h3 headings from #article-body.
 */
---

<nav class="toc" aria-label="Table of contents" id="toc">
  <h2 class="toc__title">In this article</h2>
  <ol class="toc__list" id="toc-list">
    <!-- Populated by JS -->
  </ol>
</nav>

<script>
  function buildTOC() {
    const article = document.getElementById('article-body');
    const tocList = document.getElementById('toc-list');
    const toc = document.getElementById('toc');
    if (!article || !tocList || !toc) return;

    const headings = article.querySelectorAll('h2, h3');
    if (headings.length < 3) {
      toc.style.display = 'none';
      return;
    }

    headings.forEach((heading, i) => {
      const id = heading.id || `heading-${i}`;
      heading.id = id;

      const li = document.createElement('li');
      li.className = heading.tagName === 'H3' ? 'toc__item toc__item--sub' : 'toc__item';

      const a = document.createElement('a');
      a.href = `#${id}`;
      a.textContent = heading.textContent || '';
      a.className = 'toc__link';

      li.appendChild(a);
      tocList.appendChild(li);
    });
  }
  buildTOC();
</script>
