---
import BaseLayout from './BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import { render } from 'astro:content';

interface Props {
  entry: any;
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const { title, description, pubDate, category, tags, author, image } = entry.data;

const wordCount = entry.body?.split(/\s+/).length ?? 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 220));

const formattedDate = new Date(pubDate).toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout title={title} description={description} image={image}>
  <div class="article-hero">
    <div class="article-hero__inner">
      <header class="article-header">
        <span class="article-header__category">{category}</span>
        <h1 class="article-header__title">{title}</h1>
        <div class="article-header__meta">
          <span>{formattedDate}</span>
          <span>&middot;</span>
          <span>{readingTime} min read</span>
          <span>&middot;</span>
          <span>{author}</span>
        </div>
        {tags && tags.length > 0 && (
          <div class="article-header__tags">
            {tags.map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </header>
    </div>
  </div>

  <article class="container container--narrow">
    <!-- Top ad: leaderboard above article -->
    <AdSlot slot="top" />

    <div class="prose" id="article-body">
      <Content />
    </div>

    <!-- Bottom ad: after article content -->
    <AdSlot slot="bottom" />

    <div class="author-box">
      <p>Written by <span class="author-box__name">{author}</span></p>
      <p>Published on LogisticsEdge — UK logistics, customs, and supply chain intelligence.</p>
    </div>
  </article>

  <!-- Mid-article ad injection: inserts ad after 3rd heading -->
  <script>
    function injectMidArticleAd() {
      const article = document.getElementById('article-body');
      if (!article) return;
      const headings = article.querySelectorAll('h2, h3');
      if (headings.length < 3) return;

      const target = headings[2];
      const ad = document.createElement('aside');
      ad.className = 'ad-slot ad-slot--mid ad-slot--rectangle';
      ad.setAttribute('aria-label', 'Advertisement');
      ad.innerHTML = `
        <span class="ad-slot__label">Advertisement</span>
        <div class="ad-slot__content">
          <!-- MID-ARTICLE AD UNIT: Replace with AdSense or affiliate -->
        </div>
      `;
      target.parentNode?.insertBefore(ad, target);
    }
    injectMidArticleAd();
  </script>
</BaseLayout>
