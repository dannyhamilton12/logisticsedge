---
import BaseLayout from './BaseLayout.astro';
import { render } from 'astro:content';

interface Props {
  entry: any;
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const { title, description, pubDate, category, tags, author, image } = entry.data;

// Reading time estimate: ~220 words per minute
const wordCount = entry.body?.split(/\s+/).length ?? 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 220));

const formattedDate = new Date(pubDate).toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout title={title} description={description} image={image}>
  <article class="container container--narrow">
    <header class="article-header">
      <p class="article-header__category">{category}</p>
      <h1 class="article-header__title">{title}</h1>
      <div class="article-header__meta">
        <span>{formattedDate}</span>
        <span>&middot;</span>
        <span>{readingTime} min read</span>
        <span>&middot;</span>
        <span>{author}</span>
      </div>
      {tags && tags.length > 0 && (
        <div class="article-header__tags">
          {tags.map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="prose">
      <Content />
    </div>

    <div class="author-box">
      <p>Written by <span class="author-box__name">{author}</span></p>
      <p>Published on LogisticsEdge &mdash; UK logistics, customs, and supply chain intelligence.</p>
    </div>
  </article>
</BaseLayout>
