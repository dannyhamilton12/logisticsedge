---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="error-page">
    <div class="error-page__inner">
      <span class="error-page__code">404</span>
      <h1 class="error-page__title">Page not found</h1>
      <p class="error-page__text">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="error-page__actions">
        <a href="/" class="btn btn--primary">Back to homepage</a>
        <a href="/articles/" class="btn btn--outline-dark">Browse articles</a>
      </div>
    </div>
  </div>
</BaseLayout>
