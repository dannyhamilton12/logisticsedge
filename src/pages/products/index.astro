---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const products = await getCollection('products', ({ data }) => !data.draft);
---

<BaseLayout title="Products" description="Toolkits, guides, and templates for UK logistics and customs professionals.">
  <div class="container">
    <header class="page-header">
      <h1 class="page-header__title">Products &amp; Resources</h1>
      <p class="page-header__description">
        Practical toolkits, templates, and guides built for UK logistics and customs professionals.
      </p>
    </header>

    {products.length > 0 ? (
      <div class="card-grid">
        {products.map((product) => (
          <article class="card">
            <p class="card__category">{product.data.type}</p>
            <h2 class="card__title">
              <a href={`/products/${product.id}/`}>{product.data.title}</a>
            </h2>
            <p class="card__description">{product.data.description}</p>
            <p class="card__meta">{product.data.price}</p>
          </article>
        ))}
      </div>
    ) : (
      <p>Products launching soon. Subscribe to be notified.</p>
    )}
  </div>
</BaseLayout>
