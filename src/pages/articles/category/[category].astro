---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const validCategories = ['customs', 'logistics', 'trade', 'supply-chain', 'warehousing', 'compliance'];

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  const categories = [...new Set(articles.map(a => a.data.category))];
  return categories.map(category => ({
    params: { category },
    props: {
      articles: articles
        .filter(a => a.data.category === category)
        .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()),
    },
  }));
}

const { category } = Astro.params;
const { articles } = Astro.props;

const categoryLabels: Record<string, string> = {
  customs: 'Customs',
  logistics: 'Logistics',
  trade: 'Trade',
  'supply-chain': 'Supply Chain',
  warehousing: 'Warehousing',
  compliance: 'Compliance',
};

const categoryDescriptions: Record<string, string> = {
  customs: 'UK customs procedures, duties, declarations, and compliance guidance.',
  logistics: 'Freight operations, shipping, ports, and transport management.',
  trade: 'International trade, Incoterms, country guides, and trade agreements.',
  'supply-chain': 'Supply chain strategy, risk management, and optimisation.',
  warehousing: '3PL management, fulfilment, warehouse operations, and KPIs.',
  compliance: 'Regulatory compliance, EORI, AEO, and documentation requirements.',
};

const label = categoryLabels[category!] || category;
const desc = categoryDescriptions[category!] || `Articles about ${label}.`;

function getCategoryClass(cat: string) {
  const map: Record<string, string> = {
    customs: 'card__image--customs',
    logistics: 'card__image--logistics',
    trade: 'card__image--trade',
    'supply-chain': 'card__image--supply-chain',
    warehousing: 'card__image--warehousing',
  };
  return map[cat?.toLowerCase()] || 'card__image--default';
}
---

<BaseLayout title={`${label} Articles`} description={desc}>
  <header class="page-header">
    <div class="page-header__inner">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol class="breadcrumbs__list">
          <li class="breadcrumbs__item">
            <a href="/" class="breadcrumbs__link">Home</a>
            <span class="breadcrumbs__sep">/</span>
          </li>
          <li class="breadcrumbs__item">
            <a href="/articles/" class="breadcrumbs__link">Articles</a>
            <span class="breadcrumbs__sep">/</span>
          </li>
          <li class="breadcrumbs__item">
            <span class="breadcrumbs__current" aria-current="page">{label}</span>
          </li>
        </ol>
      </nav>
      <h1 class="page-header__title">{label}</h1>
      <p class="page-header__description">{desc}</p>
    </div>
  </header>

  <div class="container">
    <section class="section">
      <p style="color: var(--color-text-muted); font-size: 0.875rem; margin-bottom: 1.5rem;">
        {articles.length} {articles.length === 1 ? 'article' : 'articles'}
      </p>
      {articles.length > 0 ? (
        <div class="card-grid">
          {articles.map((article) => {
            const date = new Date(article.data.pubDate).toLocaleDateString('en-GB', {
              day: 'numeric',
              month: 'short',
              year: 'numeric',
            });
            const wordCount = article.body?.split(/\s+/).length ?? 0;
            const readTime = Math.max(1, Math.ceil(wordCount / 220));
            return (
              <article class="card">
                <div class={`card__image ${getCategoryClass(article.data.category)}`} style={article.data.image ? `background-image: linear-gradient(to bottom, rgba(0,0,0,0) 40%, rgba(0,0,0,0.5) 100%), url(${article.data.image}); background-size: cover; background-position: center;` : ''}>
                  <span class="card__image-label">{article.data.category}</span>
                </div>
                <div class="card__body">
                  <h2 class="card__title">
                    <a href={`/articles/${article.id}/`}>{article.data.title}</a>
                  </h2>
                  <p class="card__description">{article.data.description.slice(0, 140)}...</p>
                  <p class="card__meta">
                    <span>{date}</span>
                    <span class="card__meta-dot"></span>
                    <span>{readTime} min read</span>
                  </p>
                </div>
              </article>
            );
          })}
        </div>
      ) : (
        <p>No articles in this category yet.</p>
      )}
    </section>
  </div>
</BaseLayout>
