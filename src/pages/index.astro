---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const latestArticles = allArticles
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 6);

const allProducts = await getCollection('products', ({ data }) => !data.draft);
const featuredProducts = allProducts.filter(p => p.data.price !== '0').slice(0, 3);

function getCategoryClass(category: string) {
  const map: Record<string, string> = {
    customs: 'card__image--customs',
    logistics: 'card__image--logistics',
    trade: 'card__image--trade',
    'supply-chain': 'card__image--supply-chain',
    warehousing: 'card__image--warehousing',
  };
  return map[category?.toLowerCase()] || 'card__image--default';
}
---

<BaseLayout title="LogisticsEdge">
  <!-- Hero -->
  <section class="hero">
    <div class="hero__inner">
      <span class="hero__badge">UK Logistics &amp; Customs Intelligence</span>
      <h1 class="hero__title">Expert insight for logistics professionals</h1>
      <p class="hero__subtitle">
        Practical guides on customs compliance, freight operations, and supply chain
        strategy. Built for professionals working in and with the UK.
      </p>
      <div class="hero__actions">
        <a href="/articles/" class="btn btn--primary">Browse articles</a>
        <a href="/products/" class="btn btn--outline">Digital products</a>
      </div>
      <div class="hero__stat-strip">
        <div class="hero__stat">
          <div class="hero__stat-value">{allArticles.length}</div>
          <div class="hero__stat-label">In-depth guides</div>
        </div>
        <div class="hero__stat">
          <div class="hero__stat-value">{allProducts.length}</div>
          <div class="hero__stat-label">Digital products</div>
        </div>
        <div class="hero__stat">
          <div class="hero__stat-value">Free</div>
          <div class="hero__stat-label">Lead magnets</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="section container">
    <div class="section__header">
      <h2 class="section__heading">Latest Articles</h2>
      <a href="/articles/" class="section__link">View all &rarr;</a>
    </div>
    {latestArticles.length > 0 ? (
      <div class="card-grid">
        {latestArticles.map((article) => {
          const date = new Date(article.data.pubDate).toLocaleDateString('en-GB', {
            day: 'numeric',
            month: 'short',
            year: 'numeric',
          });
          const wordCount = article.body?.split(/\s+/).length ?? 0;
          const readTime = Math.max(1, Math.ceil(wordCount / 220));
          return (
            <article class="card">
              <div class={`card__image ${getCategoryClass(article.data.category)}`} style={article.data.image ? `background-image: linear-gradient(to bottom, rgba(0,0,0,0) 40%, rgba(0,0,0,0.5) 100%), url(${article.data.image}); background-size: cover; background-position: center;` : ''}>
                <span class="card__image-label">{article.data.category}</span>
              </div>
              <div class="card__body">
                <h3 class="card__title">
                  <a href={`/articles/${article.id}/`}>{article.data.title}</a>
                </h3>
                <p class="card__description">{article.data.description.slice(0, 140)}...</p>
                <p class="card__meta">
                  <span>{date}</span>
                  <span class="card__meta-dot"></span>
                  <span>{readTime} min read</span>
                </p>
              </div>
            </article>
          );
        })}
      </div>
    ) : (
      <p>Articles coming soon.</p>
    )}
  </section>

  <!-- Featured Products -->
  <section class="section--alt">
    <div class="container">
      <div class="section__header">
        <h2 class="section__heading">Digital Products</h2>
        <a href="/products/" class="section__link">View all &rarr;</a>
      </div>
      {featuredProducts.length > 0 ? (
        <div class="card-grid">
          {featuredProducts.map((product) => (
            <article class="card card--product">
              <div class="card__image card__image--default">
                <span class="card__image-label">{product.data.type}</span>
              </div>
              <div class="card__body">
                <h3 class="card__title">
                  <a href={`/products/${product.id}/`}>{product.data.title}</a>
                </h3>
                <p class="card__description">{product.data.description.slice(0, 120)}...</p>
                <p class="card__price">&pound;{product.data.price}</p>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <p>Products launching soon.</p>
      )}
    </div>
  </section>

  <!-- Email CTA -->
  <section class="container" style="padding: 4rem 1.5rem;">
    <div class="cta-section">
      <h2 class="cta-section__title">Stay ahead of the curve</h2>
      <p class="cta-section__text">
        Get practical UK logistics and customs insight delivered to your inbox.
        No fluff, no spam.
      </p>
      <!-- NEWSLETTER: Update the form action with your Buttondown username -->
      <!-- Sign up free at https://buttondown.com — or swap for Mailchimp/ConvertKit -->
      <form
        action="https://buttondown.com/api/emails/newsletter-subscribe"
        method="post"
        class="newsletter-form"
        target="_blank"
      >
        <input type="hidden" name="tag" value="logisticsedge" />
        <div class="newsletter-form__row">
          <input
            type="email"
            name="email"
            placeholder="you@company.com"
            required
            class="newsletter-form__input"
            aria-label="Email address"
          />
          <button type="submit" class="btn btn--primary newsletter-form__btn">Subscribe</button>
        </div>
        <p class="newsletter-form__hint">Free. Unsubscribe anytime. No spam.</p>
      </form>
    </div>
  </section>
</BaseLayout>
